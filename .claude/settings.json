{
  "plansDirectory": "./plans",
  "permissions": {
    "allow": [
      "Bash(pnpm run lint*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run dev*)",
      "Bash(pnpm prettier:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm audit:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git stash:*)",
      "Bash(git add:*)"
    ],
    "deny": ["Bash(curl:*)", "Read(./.env)", "Read(./.env.*)"]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
